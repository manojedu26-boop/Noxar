{
  "name": "noxar-desktop-core",
  "private": true,
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "dependencies": {},
  "devDependencies": {
    "autoprefixer": "^10.4.18",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manojedu26-boop/Noxar.git"
  },
  "build": {
    "appId": "com.noxar.desktop",
    "productName": "noxar",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "logo.png",
      "publish": null
    },
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "logo.png"
    ]
  }
}
